# GeoServer
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=geoserver

# PostgreSQL
POSTGRES_DB=dxp
POSTGRES_USER=dxp
POSTGRES_PASSWORD=dxp

# アプリ設定
HTTP_PORT=80

# ============================================================
# Auth0 認証設定
# Auth0 テナント作成後に以下を設定してください
# セットアップ手順: docs/auth0-setup.md
# ============================================================

# Auth0 共通
AUTH0_ISSUER_BASE_URL=https://YOUR_DOMAIN.auth0.com
AUTH0_NAMESPACE=https://dxp/

# frontend 用 Auth0 Application（Regular Web App）
FRONTEND_AUTH0_SECRET=use-a-long-random-string-here-32-chars-min
FRONTEND_AUTH0_BASE_URL=http://localhost
FRONTEND_AUTH0_CLIENT_ID=YOUR_FRONTEND_CLIENT_ID
FRONTEND_AUTH0_CLIENT_SECRET=YOUR_FRONTEND_CLIENT_SECRET

# Auth0 Management API（M2M Application）- ユーザー管理用
AUTH0_MANAGEMENT_CLIENT_ID=YOUR_M2M_CLIENT_ID
AUTH0_MANAGEMENT_CLIENT_SECRET=YOUR_M2M_CLIENT_SECRET

# operator 用 Auth0 Application（Regular Web App）
OPERATOR_AUTH0_SECRET=use-a-long-random-string-here-32-chars-min
OPERATOR_AUTH0_BASE_URL=http://localhost/operator
OPERATOR_AUTH0_CLIENT_ID=YOUR_OPERATOR_CLIENT_ID
OPERATOR_AUTH0_CLIENT_SECRET=YOUR_OPERATOR_CLIENT_SECRET
